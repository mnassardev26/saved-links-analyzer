{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~*": [
        "./*"
      ]
    },
    "types": [
      "chrome",
      "node",
      "vitest/globals"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true
  }
}
